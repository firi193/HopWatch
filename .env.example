# Database
DATABASE_URL=postgresql://hopwatch:hopwatch@localhost:5432/hopwatch

# Redis
REDIS_URL=redis://localhost:6379

# Gemini
GEMINI_API_KEY=

# Alerting
SLACK_WEBHOOK_URL=

# Detection thresholds (configurable)
TIER2_HIGH_THRESHOLD=0.7
TIER2_MEDIUM_THRESHOLD=0.3
JUDGE_MEDIUM_WINDOW_MS=900000

# Storage
CONTENT_ARCHIVE_DIR=./data/archive

# Service
PORT=3000
NODE_ENV=development

# Set to true in development when onnxruntime-node is not installed.
# Tier 1 pattern matching still runs; tier2_score will be null.
# Remove (or set to false) in production once onnxruntime-node is available.
DISABLE_TIER2=true
